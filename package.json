{

  "name": "friendly-ecommerce-angular",

  "version": "0.0.0",

  "scripts": {

    "ng": "ng",

    "start": "ng serve",

    "build": "ng build",

    "watch": "ng build --watch --configuration development",

    "test": "ng test",

    "serve:ssr:friendly_ecommerce_angular": "node dist/friendly_ecommerce_angular/server/server.mjs",

    "gen:auth": "ng-openapi-gen --config openapi-configs/auth.json",

    "gen:user": "ng-openapi-gen --config openapi-configs/user.json",

    "gen:product": "ng-openapi-gen --config openapi-configs/product.json",

    "gen:order": "ng-openapi-gen --config openapi-configs/order.json",

    "gen:payment": "ng-openapi-gen --config openapi-configs/payment.json",

    "gen:inventory": "ng-openapi-gen --config openapi-configs/inventory.json",
    "gen:cart": "ng-openapi-gen --config openapi-configs/cart.json",

    "gen:all": "npm run gen:auth && npm run gen:user && npm run gen:product && npm run gen:order && npm run gen:payment && npm run gen:inventory && npm run gen:cart"

  },

  "prettier": {

    "printWidth": 100,

    "singleQuote": true,

    "overrides": [

      {

        "files": "*.html",

        "options": {

          "parser": "angular"

        }

      }

    ]

  },

  "private": true,

  "packageManager": "npm@10.8.2",

  "dependencies": {

    "@angular/common": "^21.1.0",

    "@angular/compiler": "^21.1.0",

    "@angular/core": "^21.1.0",

    "@angular/forms": "^21.1.0",

    "@angular/platform-browser": "^21.1.0",

    "@angular/platform-server": "^21.1.0",

    "@angular/router": "^21.1.0",

    "@angular/ssr": "^21.1.1",

    "@eduvidu/angular-razorpay": "^0.0.9",

    "@fortawesome/angular-fontawesome": "^4.0.0",

    "@fortawesome/fontawesome-svg-core": "^7.2.0",

    "@fortawesome/free-brands-svg-icons": "^7.2.0",

    "@fortawesome/free-solid-svg-icons": "^7.2.0",

    "@tailwindcss/vite": "^4.2.2",

    "@tanstack/angular-query-experimental": "^5.96.2",

    "express": "^5.1.0",

    "jwt-decode": "^4.0.0",

    "ngxtension": "^7.2.0",

    "rxjs": "~7.8.0",

    "tslib": "^2.3.0"

  },

  "devDependencies": {

    "@analogjs/vite-plugin-angular": "^2.4.0",

    "@angular/build": "^21.1.1",

    "@angular/cli": "^21.1.1",

    "@angular/compiler-cli": "^21.1.0",

    "@tailwindcss/postcss": "^4.2.2",

    "@types/express": "^5.0.1",

    "@types/node": "^20.17.19",

    "jsdom": "^27.1.0",

    "postcss": "^8.5.8",

    "tailwindcss": "^4.2.2",

    "typescript": "~5.9.2",

    "vitest": "^4.0.8"

  }

}

